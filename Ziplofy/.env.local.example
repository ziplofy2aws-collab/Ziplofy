# Copy to `.env.local` and restart `npm run dev`

# Static theme editor — local dev only (leave unset/false in production)
VITE_THEME_EDITOR_STATIC_MODE=true

# Bundled pack under src/theme-packs/horizon/ (Horizon is the only remote theme)
# VITE_THEME_EDITOR_STATIC_PACK=horizon
# VITE_THEME_EDITOR_STATIC_JS_URL=http://localhost:5180/remote-themes/horizon/theme.js
# VITE_THEME_EDITOR_STATIC_CSS_URL=http://localhost:5180/remote-themes/horizon/theme.css

# Preview runs in render-store iframe (port 5180). After theme source changes:
#   cd remote-themes/horizon && npm run build
# render-store dev serves remote-themes/horizon/dist/ (no copy into Ziplofy/public).
# Requires render-store on :5180 and Ziplofy admin on :5173.
# Use a real store id for products/cart in preview (or select store in admin):
# VITE_THEME_EDITOR_STATIC_STORE_ID=<your-mongodb-store-id>

# Or load JSON from public/static-editor-theme/ instead:
# VITE_THEME_EDITOR_STATIC_BASE_URL=/static-editor-theme

# Live preview assets (set when you have theme.js built)
# VITE_THEME_EDITOR_STATIC_JS_URL=http://localhost:5180/remote-theme-runtime/your-theme.js
# VITE_THEME_EDITOR_STATIC_CSS_URL=http://localhost:5180/remote-theme-runtime/your-theme.css

# VITE_THEME_EDITOR_STATIC_THEME_NAME=Reference theme
