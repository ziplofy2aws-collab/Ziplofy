{
  "id": "makeup",
  "name": "Lumière Beauty",
  "version": "1.0.0",
  "type": "react-remote",
  "configMode": "sections",
  "assets": {
    "themeJs": "theme.js",
    "themeCss": "theme.css",
    "defaultConfig": "theme.default-config.json",
    "schema": "theme.schema.json"
  },
  "templates": ["index", "product", "cart", "login", "signup", "forgot_password", "profile", "orders"],
  "capabilities": {
    "sections": true,
    "blocks": true,
    "globalSettings": true,
    "livePreview": true
  },
  "blockTypes": {
    "basic": [
      { "id": "button", "label": "Button" },
      { "id": "heading", "label": "Heading" },
      { "id": "logo", "label": "Logo" },
      { "id": "text", "label": "Text" }
    ],
    "decorative": [
      { "id": "jumbo-text", "label": "Jumbo text", "extendedOnly": true },
      { "id": "marquee", "label": "Marquee", "extendedOnly": true }
    ],
    "layout": [
      { "id": "group", "label": "Group" },
      { "id": "spacer", "label": "Spacer", "extendedOnly": true }
    ],
    "links": [
      { "id": "menu", "label": "Menu", "extendedOnly": true },
      { "id": "popup-link", "label": "Popup link", "extendedOnly": true }
    ],
    "product": [
      { "id": "buy-buttons", "label": "Buy buttons", "extendedOnly": true },
      { "id": "description", "label": "Description", "extendedOnly": true },
      { "id": "price", "label": "Price", "extendedOnly": true },
      { "id": "product-card", "label": "Product card", "extendedOnly": true },
      { "id": "review-stars", "label": "Review stars", "extendedOnly": true },
      { "id": "title", "label": "Title", "extendedOnly": true },
      { "id": "variant-picker", "label": "Variant picker", "extendedOnly": true }
    ]
  },
  "sectionBlocks": {
    "hero": ["heading", "button", "text"],
    "featured-collection": ["product-card", "price", "title"],
    "reviews": ["review-stars", "text"],
    "icons-with-text": ["text", "heading"]
  }
}
