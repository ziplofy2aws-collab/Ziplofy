{
  "version": "1.0.0",
  "themeId": "makeup",
  "themeName": "Lumière Beauty",
  "settings": {
    "colors": {
      "primary": "#9d174d",
      "primarySoft": "#fdf2f8",
      "accent": "#d4a574",
      "background": "#fffaf8",
      "surface": "#ffffff",
      "text": "#1c1917",
      "textMuted": "#78716c",
      "border": "#f5e6e8"
    },
    "typography": {
      "fontFamily": "'Cormorant Garamond', Georgia, serif",
      "fontFamilyBody": "'DM Sans', system-ui, sans-serif",
      "headingScale": 1
    }
  },
  "sections": {
    "header": {
      "id": "header",
      "type": "header",
      "label": "Header",
      "enabled": true,
      "settings": {
        "sticky": true,
        "showSearch": true,
        "showCart": true,
        "announcement": "Free shipping on orders over ₹999 · New spring collection live"
      },
      "blocks": {
        "logo": {
          "type": "logo",
          "label": "Logo",
          "settings": {
            "text": "Lumière",
            "tagline": "Beauty redefined"
          }
        },
        "menu": {
          "type": "menu",
          "label": "Menu",
          "settings": {
            "menuLabel": "Main menu",
            "items": [
              { "label": "Shop", "href": "/products" },
              { "label": "Collections", "href": "/collection" },
              { "label": "About", "href": "/#about" }
            ]
          }
        }
      },
      "block_order": ["logo", "menu"]
    },
    "footer": {
      "id": "footer",
      "type": "footer",
      "label": "Footer",
      "enabled": true,
      "settings": {
        "newsletterTitle": "Join the beauty circle",
        "newsletterSubtitle": "Exclusive offers, tips, and early access to new launches.",
        "copyright": "© 2026 Lumière Beauty. All rights reserved."
      },
      "blocks": {
        "links_shop": {
          "type": "link_list",
          "label": "Shop",
          "settings": {
            "title": "Shop",
            "links": [
              { "label": "All products", "href": "/products" },
              { "label": "Best sellers", "href": "/products" },
              { "label": "Gift sets", "href": "/products" }
            ]
          }
        },
        "links_support": {
          "type": "link_list",
          "label": "Support",
          "settings": {
            "title": "Support",
            "links": [
              { "label": "Contact", "href": "/#contact" },
              { "label": "Shipping", "href": "/#shipping" },
              { "label": "Returns", "href": "/#returns" }
            ]
          }
        },
        "social": {
          "type": "social",
          "label": "Social",
          "settings": {
            "instagram": "https://instagram.com",
            "tiktok": "https://tiktok.com",
            "pinterest": "https://pinterest.com"
          }
        }
      },
      "block_order": ["links_shop", "links_support", "social"]
    }
  },
  "templates": {
    "index": {
      "name": "Home page",
      "label": "Home",
      "sections": {
        "hero_main": {
          "type": "hero",
          "label": "Hero",
          "enabled": true,
          "settings": {
            "eyebrow": "Spring 2026",
            "title": "Radiance begins with you",
            "subtitle": "Luxury makeup crafted for every skin tone. Clean ingredients, professional results.",
            "ctaLabel": "Shop the collection",
            "ctaHref": "/products",
            "secondaryCtaLabel": "Explore bestsellers",
            "secondaryCtaHref": "/products",
            "imageUrl": "",
            "overlayOpacity": 0.35,
            "textAlign": "left",
            "showCta": true
          }
        },
        "featured_collection": {
          "type": "featured-collection",
          "label": "Featured collection",
          "enabled": true,
          "settings": {
            "title": "Bestsellers",
            "subtitle": "Customer favorites this season",
            "layout": "grid",
            "productsToShow": 8,
            "showVendor": false,
            "showRating": true
          }
        },
        "promo_banner": {
          "type": "image-banner",
          "label": "Promo banner",
          "enabled": true,
          "settings": {
            "title": "The velvet lip collection",
            "subtitle": "12 new shades · Limited edition packaging",
            "ctaLabel": "Discover lips",
            "ctaHref": "/products",
            "backgroundGradient": "linear-gradient(135deg, #831843 0%, #be185d 50%, #fbcfe8 100%)"
          }
        },
        "reviews": {
          "type": "reviews",
          "label": "Reviews",
          "enabled": true,
          "settings": {
            "title": "Loved by beauty enthusiasts",
            "subtitle": "Real reviews from our community",
            "showAvatars": true
          },
          "blocks": {
            "review_1": {
              "type": "review",
              "settings": {
                "author": "Priya S.",
                "rating": 5,
                "text": "The foundation melts into my skin — never cakey. Holy grail status.",
                "product": "Silk Skin Foundation"
              }
            },
            "review_2": {
              "type": "review",
              "settings": {
                "author": "Maya K.",
                "rating": 5,
                "text": "Packaging is gorgeous and the pigment payoff on the eyeshadow palette is insane.",
                "product": "Sunset Muse Palette"
              }
            },
            "review_3": {
              "type": "review",
              "settings": {
                "author": "Elena R.",
                "rating": 5,
                "text": "Finally a brand that matches my undertone perfectly. Customer for life.",
                "product": "Contour Duo Stick"
              }
            }
          },
          "block_order": ["review_1", "review_2", "review_3"]
        },
        "icons_with_text": {
          "type": "icons-with-text",
          "label": "Icons with text",
          "enabled": true,
          "settings": {
            "title": "Why Lumière"
          },
          "blocks": {
            "icon_1": {
              "type": "icon_text",
              "settings": {
                "icon": "leaf",
                "title": "Clean beauty",
                "text": "Formulated without parabens, sulfates, or phthalates."
              }
            },
            "icon_2": {
              "type": "icon_text",
              "settings": {
                "icon": "truck",
                "title": "Fast delivery",
                "text": "Free shipping on orders over ₹999 nationwide."
              }
            },
            "icon_3": {
              "type": "icon_text",
              "settings": {
                "icon": "shield",
                "title": "Secure checkout",
                "text": "Your payment and data are always protected."
              }
            }
          },
          "block_order": ["icon_1", "icon_2", "icon_3"]
        }
      },
      "section_order": ["hero_main", "featured_collection", "promo_banner", "reviews", "icons_with_text"]
    },
    "product": {
      "name": "Product",
      "label": "Product",
      "sections": {
        "product_main": {
          "type": "product-main",
          "label": "Product details",
          "enabled": true,
          "settings": {
            "showVendor": true,
            "showSku": true,
            "showRating": true,
            "showShareButtons": true,
            "showIngredientsTab": true,
            "showHowToUseTab": true,
            "showReviewsTab": true,
            "galleryLayout": "thumbnails-left",
            "stickyAddToCart": true
          }
        },
        "product_recommendations": {
          "type": "product-recommendations",
          "label": "You may also like",
          "enabled": true,
          "settings": {
            "title": "Complete your routine",
            "productsToShow": 4
          }
        }
      },
      "section_order": ["product_main", "product_recommendations"]
    },
    "cart": {
      "name": "Cart",
      "label": "Cart",
      "sections": {
        "cart_main": {
          "type": "cart-main",
          "label": "Cart",
          "enabled": true,
          "settings": {
            "showOrderNote": true,
            "showTrustBadges": true,
            "emptyCartTitle": "Your beauty bag is empty",
            "emptyCartCta": "Continue shopping"
          }
        }
      },
      "section_order": ["cart_main"]
    },
    "login": {
      "name": "Login",
      "label": "Login",
      "sections": {
        "auth_login": {
          "type": "auth-form",
          "label": "Login form",
          "enabled": true,
          "settings": {
            "mode": "login",
            "title": "Welcome back",
            "subtitle": "Sign in to track orders and save your favorites.",
            "showSocialLogin": false
          }
        }
      },
      "section_order": ["auth_login"]
    },
    "signup": {
      "name": "Signup",
      "label": "Signup",
      "sections": {
        "auth_signup": {
          "type": "auth-form",
          "label": "Signup form",
          "enabled": true,
          "settings": {
            "mode": "signup",
            "title": "Create your account",
            "subtitle": "Join Lumière for exclusive rewards and faster checkout.",
            "showSocialLogin": false
          }
        }
      },
      "section_order": ["auth_signup"]
    },
    "forgot_password": {
      "name": "Forgot password",
      "label": "Forgot password",
      "sections": {
        "auth_forgot": {
          "type": "auth-form",
          "label": "Forgot password",
          "enabled": true,
          "settings": {
            "mode": "forgot",
            "title": "Reset your password",
            "subtitle": "Enter your email and we'll send you a reset link.",
            "showSocialLogin": false
          }
        }
      },
      "section_order": ["auth_forgot"]
    },
    "profile": {
      "name": "Profile",
      "label": "Profile",
      "sections": {
        "profile_main": {
          "type": "profile-main",
          "label": "Profile",
          "enabled": true,
          "settings": {
            "title": "My account",
            "showAddresses": true,
            "showNewsletterToggle": true
          }
        }
      },
      "section_order": ["profile_main"]
    },
    "orders": {
      "name": "Orders",
      "label": "Orders",
      "sections": {
        "orders_main": {
          "type": "orders-main",
          "label": "Order history",
          "enabled": true,
          "settings": {
            "title": "Your orders",
            "emptyTitle": "No orders yet",
            "emptySubtitle": "When you place an order, it will appear here."
          }
        }
      },
      "section_order": ["orders_main"]
    }
  }
}
