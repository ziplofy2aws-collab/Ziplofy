{
  "id": "horizon",
  "name": "Horizon",
  "version": "1.0.0",
  "type": "react-remote",
  "configMode": "sections",
  "assets": {
    "themeJs": "theme.js",
    "themeCss": "theme.css",
    "defaultConfig": "theme.default-config.json",
    "schema": "theme.schema.json"
  },
  "templates": [
    "index",
    "product",
    "cart",
    "login",
    "signup",
    "forgot_password",
    "profile",
    "orders",
    "preferences"
  ],
  "capabilities": {
    "sections": true,
    "blocks": true,
    "globalSettings": true,
    "livePreview": true
  },
  "blockTypes": {
    "basic": [
      {
        "id": "announcement",
        "label": "Announcement"
      },
      {
        "id": "button",
        "label": "Button"
      },
      {
        "id": "heading",
        "label": "Heading"
      },
      {
        "id": "text",
        "label": "Text"
      },
      {
        "id": "logo",
        "label": "Logo"
      }
    ],
    "product": [
      {
        "id": "product-card",
        "label": "Product card"
      },
      {
        "id": "price",
        "label": "Price"
      },
      {
        "id": "title",
        "label": "Title"
      }
    ],
    "layout": [
      {
        "id": "accordion-row",
        "label": "Accordion row"
      }
    ]
  },
  "sectionBlocks": {
    "announcement-bar": [
      "announcement"
    ],
    "hero": [
      "button",
      "heading",
      "text"
    ],
    "featured-collection": [
      "product-card",
      "title"
    ],
    "header": [
      "logo",
      "menu"
    ],
    "footer": [
      "newsletter"
    ],
    "footer-utilities": [
      "copyright",
      "policy_links",
      "social"
    ],
    "contact-form": [],
    "email-signup": [],
    "custom-section": [],
    "product-highlight": [],
    "editorial": [],
    "editorial-jumbo": [],
    "image-compare": [],
    "image-with-text": [],
    "storytelling-logo": [],
    "storytelling-video": [],
    "faq": [
      "heading",
      "accordion",
      "accordion-row"
    ],
    "icons-with-text": [
      "icon-with-text-item"
    ],
    "multicolumn": [
      "multicolumn-item"
    ],
    "pull-quote": [],
    "rich-text": [],
    "text-marquee": [],
    "blog-posts-carousel": [
      "blog-post-card"
    ],
    "blog-posts-editorial": [
      "blog-post-card"
    ],
    "blog-posts-grid": [
      "blog-post-card"
    ],
    "storytelling-carousel": [
      "carousel-slide"
    ]
  },
  "benchmark": true
}
