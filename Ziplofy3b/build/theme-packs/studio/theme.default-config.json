            "sidePanelTitle": "Welcome back"
          },
          "blocks": {
            "form_fields": {
              "type": "form-fields",
              "blocks": {
                "email_field": {
                  "type": "email",
                  "settings": {
                    "placeholder": "Email"
                  }
                },
                "password_field": {
                  "type": "password",
                  "settings": {
                    "placeholder": "Password"
                  }
                }
              },
              "block_order": [
                "email_field",
                "password_field"
              ],
              "nested_block_order": [
                "email_field",
                "password_field"
              ]
            },
            "primary_button": {
              "type": "primary-button",
              "settings": {
                "label": "Continue",
                "loadingLabel": "Please wait…"
              }
            },
            "footer_link": {
              "type": "footer-link",
              "blocks": {
                "signup_prompt": {
                  "type": "prompt",
                  "settings": {
                    "text": "New here?"
