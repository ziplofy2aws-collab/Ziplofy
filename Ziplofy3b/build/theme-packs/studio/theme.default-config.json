{
  "version": "1.0.0",
  "themeId": "studio",
  "themeName": "Bloom",
  "settings": {
    "colors": {
      "primary": "#be185d",
      "background": "#fff7f3",
      "text": "#431407",
      "accent": "#be185d",
      "surface": "#fff7f3",
      "muted": "#6b7280",
      "border": "#e5e7eb"
    },
    "typography": {
      "fontFamily": "'Playfair Display', Georgia, serif",
      "fontFamilyBody": "system-ui, -apple-system, sans-serif",
      "baseSize": 16,
      "lineHeight": 1.5,
      "headingWeight": 600
    },
    "spacing": {
      "sectionGap": 48,
      "contentMaxWidth": 1200,
      "pagePadding": 24
    }
  },
  "sections": {
    "announcement_bar": {
      "id": "announcement_bar",
      "type": "announcement-bar",
      "enabled": true,
      "settings": {
        "enabled": true,
        "message": "Bloom — Complimentary shipping on orders over ₹799",
        "linkLabel": "Shop blooms",
        "linkHref": "/products",
        "timeToNext": 5,
        "sectionWidth": "page",
        "colorScheme": "scheme-4",
        "dividerThickness": 0,
        "paddingTop": 15,
        "paddingBottom": 15,
        "customCss": "",
        "dismissible": false,
        "icon": ""
      }
    },
    "header": {
      "id": "header",
      "type": "header",
      "enabled": true,
      "settings": {
        "sticky": true
      },
      "blocks": {
        "logo": {
          "type": "logo",
          "settings": {
            "text": "Bloom",
            "tagline": "Soft essentials"
          }
        },
        "menu": {
          "type": "menu",
          "settings": {
            "items": [
              {
                "label": "Shop",
                "href": "/products"
              },
              {
                "label": "Collections",
                "href": "/collection"
              },
              {
                "label": "About",
                "href": "/#about"
              }
            ]
          },
          "nested_block_order": [
            "link_shop",
            "link_collections",
            "link_about"
          ]
        }
      },
      "block_order": [
        "logo",
        "menu"
      ]
    },
    "footer": {
      "id": "footer",
      "type": "footer",
      "enabled": true,
      "blocks": {
        "newsletter": {
          "type": "newsletter",
          "settings": {
            "title": "Join our exclusive email list",
            "subtitle": "Be the first to hear about new drops, offers, and styling tips.",
            "placeholder": "Enter your email",
            "buttonLabel": "Subscribe"
          }
        }
      },
      "block_order": [
        "newsletter"
      ]
    },
    "footer_utilities": {
      "id": "footer_utilities",
      "type": "footer-utilities",
      "enabled": true,
      "blocks": {
        "copyright": {
          "type": "copyright",
          "settings": {
            "text": "© 2026 My Store. All rights reserved."
          }
        },
        "policy_links": {
          "type": "policy_links",
          "settings": {
            "privacyLabel": "Privacy policy",
            "privacyHref": "/pages/privacy",
            "termsLabel": "Terms of service",
            "termsHref": "/pages/terms"
          }
        },
        "social": {
          "type": "social",
          "settings": {
            "instagram": "https://instagram.com",
            "facebook": "https://facebook.com"
          }
        }
      },
      "block_order": [
        "copyright",
        "policy_links",
        "social"
      ]
    }
  },
  "templates": {
    "index": {
      "name": "Home page",
      "sections": {
        "hero_main": {
          "type": "hero",
          "enabled": true,
          "settings": {
            "eyebrow": "Spring edit",
            "title": "Wear the season",
            "subtitle": "Light fabrics, warm tones, and pieces made for slow mornings and long evenings.",
            "textAlign": "center",
            "minHeight": 520,
            "backgroundTone": "gradient",
            "fullWidth": false,
            "overlayOpacity": 0.35
          },
          "settings_field_order": [
            "templates.index.sections.hero_main.settings.eyebrow",
            "templates.index.sections.hero_main.settings.title",
            "templates.index.sections.hero_main.settings.subtitle"
          ],
          "blocks": {
            "primary_button": {
              "type": "button",
              "settings": {
                "label": "Shop now",
                "href": "/products"
              },
              "settings_field_order": [
                "templates.index.sections.hero_main.blocks.primary_button.settings.label",
                "templates.index.sections.hero_main.blocks.primary_button.settings.href"
              ]
            },
            "secondary_button": {
              "type": "button",
              "settings": {
                "label": "Learn more",
                "href": "/#about"
              },
              "settings_field_order": [
                "templates.index.sections.hero_main.blocks.secondary_button.settings.label",
                "templates.index.sections.hero_main.blocks.secondary_button.settings.href"
              ]
            }
          },
          "block_order": [
            "primary_button",
            "secondary_button"
          ]
        },
        "product_grid": {
          "type": "featured-collection",
          "enabled": true,
          "settings": {
            "productsToShow": 8,
            "subtitle": "Hand-picked for you",
            "columns": 4,
            "gap": 24,
            "showRating": true,
            "emptyMessage": "No products yet."
          },
          "settings_field_order": [
            "templates.index.sections.product_grid.settings.productsToShow"
          ],
          "blocks": {
            "collection_header": {
              "type": "collection-header",
              "settings": {
                "title": "Featured products",
                "viewAllLabel": "View all",
                "viewAllHref": "/products",
                "subtitle": "Curated selection"
              },
              "nested_block_order": [
                "collection_title",
                "view_all_button"
              ]
            },
            "product_card": {
              "type": "product-card",
              "settings": {
                "showMedia": true,
                "showTitle": true,
                "showPrice": true
              },
              "nested_block_order": [
                "media",
                "product_title",
                "price",
                "quick_view",
                "badge"
              ],
              "blocks": {
                "quick_view": {
                  "type": "quick-view",
                  "settings": {
                    "label": "Quick view",
                    "show": true
                  }
                },
                "badge": {
                  "type": "badge",
                  "settings": {
                    "saleLabel": "Sale",
                    "newLabel": "New"
                  }
                }
              },
              "block_order": [
                "media",
                "product_title",
                "price",
                "quick_view",
                "badge"
              ]
            }
          },
          "block_order": [
            "collection_header",
            "product_card"
          ]
        }
      },
      "section_order": [
        "hero_main",
        "product_grid"
      ]
    },
    "product": {
      "name": "Product",
      "sections": {
        "product_main": {
          "type": "product-main",
          "enabled": true,
          "settings": {
            "layoutMode": "split",
            "showSku": false,
            "stickyBuyBox": true
          },
          "blocks": {
            "product_media": {
              "type": "product-media",
              "settings": {
                "showImage": true
              }
            },
            "product_header": {
              "type": "product-header",
              "blocks": {
                "vendor_line": {
                  "type": "vendor-line",
                  "settings": {
                    "showVendor": true,
                    "vendorPrefix": "Sold by"
                  }
                },
                "product_title": {
                  "type": "product-title",
                  "settings": {
                    "loadingLabel": "Loading…"
                  }
                }
              },
              "block_order": [
                "vendor_line",
                "product_title"
              ],
              "nested_block_order": [
                "vendor_line",
                "product_title"
              ]
            },
            "product_content": {
              "type": "product-content",
              "blocks": {
                "description": {
                  "type": "description",
                  "settings": {
                    "showDescription": true
                  }
                },
                "price_line": {
                  "type": "price-line",
                  "settings": {
                    "priceFallback": "—"
                  }
                }
              },
              "block_order": [
                "description",
                "price_line"
              ]
            },
            "buy_box": {
              "type": "buy-box",
              "blocks": {
                "add_to_cart_button": {
                  "type": "add-to-cart",
                  "settings": {
                    "label": "Add to cart",
                    "addingLabel": "Adding…"
                  }
                },
                "quantity_field": {
                  "type": "qty",
                  "settings": {
                    "label": "Quantity",
                    "min": 1
                  }
                },
                "buy_now_button": {
                  "type": "buy-now",
                  "settings": {
                    "label": "Buy now",
                    "href": ""
                  }
                }
              },
              "block_order": [
                "quantity_field",
                "add_to_cart_button",
                "buy_now_button"
              ]
            },
            "trust_badges": {
              "type": "trust",
              "blocks": {
                "shipping_badge": {
                  "type": "badge",
                  "settings": {
                    "text": "Free shipping over ₹799"
                  }
                },
                "returns_badge": {
                  "type": "badge",
                  "settings": {
                    "text": "30-day returns"
                  }
                }
              },
              "block_order": [
                "shipping_badge",
                "returns_badge"
              ]
            }
          },
          "block_order": [
            "product_media",
            "product_header",
            "product_content",
            "buy_box",
            "trust_badges"
          ]
        }
      },
      "section_order": [
        "product_main"
      ]
    },
    "cart": {
      "name": "Cart",
      "sections": {
        "cart_main": {
          "type": "cart-main",
          "enabled": true,
          "settings": {
            "title": "Your cart",
            "subtitle": "Review items before checkout",
            "shippingNote": "Shipping calculated at checkout",
            "taxDisclaimer": "Taxes may apply"
          },
          "blocks": {
            "empty_state": {
              "type": "empty-state",
              "blocks": {
                "empty_message": {
                  "type": "empty-message",
                  "settings": {
                    "emptyTitle": "Your cart is empty"
                  }
                },
                "continue_link": {
                  "type": "continue-link",
                  "settings": {
                    "label": "Continue shopping",
                    "href": "/"
                  }
                }
              },
              "block_order": [
                "empty_message",
                "continue_link"
              ]
            },
            "line_items": {
              "type": "line-items",
              "blocks": {
                "item_actions": {
                  "type": "item-actions",
                  "settings": {
                    "removeLabel": "Remove",
                    "loadingLabel": "Loading…"
                  }
                }
              },
              "block_order": [
                "item_actions"
              ]
            },
            "cart_summary": {
              "type": "cart-summary",
              "blocks": {
                "subtotal": {
                  "type": "subtotal",
                  "settings": {
                    "label": "Subtotal:"
                  }
                },
                "checkout_button": {
                  "type": "checkout",
                  "settings": {
                    "label": "Checkout",
                    "helperText": "Secure payment"
                  }
                },
                "shipping_line": {
                  "type": "shipping",
                  "settings": {
                    "label": "Shipping",
                    "fallback": "Calculated at checkout"
                  }
                }
              },
              "block_order": [
                "subtotal",
                "shipping_line",
                "checkout_button"
              ]
            }
          },
          "block_order": [
            "empty_state",
            "line_items",
            "cart_summary"
          ]
        }
      },
      "section_order": [
        "cart_main"
      ]
    },
    "login": {
      "name": "Login",
      "sections": {
        "login_main": {
          "type": "login-main",
          "enabled": true,
          "settings": {
            "eyebrow": "Account",
