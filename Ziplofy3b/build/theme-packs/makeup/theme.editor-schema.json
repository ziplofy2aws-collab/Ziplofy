{
  "version": "1.0.0",
  "themeId": "makeup",
  "description": "Editor sidebar tree — maps to theme.config.default.json structure",
  "globalSettings": {
    "label": "Theme settings",
    "groups": [
      {
        "id": "colors",
        "label": "Colors",
        "fields": [
          { "path": "settings.colors.primary", "type": "color", "label": "Primary" },
          { "path": "settings.colors.accent", "type": "color", "label": "Accent gold" },
          { "path": "settings.colors.background", "type": "color", "label": "Page background" },
          { "path": "settings.colors.surface", "type": "color", "label": "Card surface" }
        ]
      },
      {
        "id": "typography",
        "label": "Typography",
        "fields": [
          { "path": "settings.typography.fontFamily", "type": "text", "label": "Heading font" },
          { "path": "settings.typography.fontFamilyBody", "type": "text", "label": "Body font" }
        ]
      }
    ]
  },
  "layout": {
    "header": {
      "configPath": "sections.header",
      "label": "Header",
      "blocks": [
        { "id": "logo", "configPath": "sections.header.blocks.logo", "label": "Logo" },
        { "id": "menu", "configPath": "sections.header.blocks.menu", "label": "Menu" }
      ],
      "settingsFields": [
        { "path": "sections.header.settings.announcement", "type": "text", "label": "Announcement bar" },
        { "path": "sections.header.settings.sticky", "type": "boolean", "label": "Sticky header" }
      ]
    },
    "footer": {
      "configPath": "sections.footer",
      "label": "Footer",
      "blocks": [
        { "id": "links_shop", "label": "Shop links" },
        { "id": "links_support", "label": "Support links" },
        { "id": "social", "label": "Social" }
      ],
      "settingsFields": [
        { "path": "sections.footer.settings.newsletterTitle", "type": "text", "label": "Newsletter title" },
        { "path": "sections.footer.settings.copyright", "type": "text", "label": "Copyright" }
      ]
    }
  },
  "templates": [
    {
      "id": "index",
      "label": "Home page",
      "sections": [
        {
          "id": "hero_main",
          "type": "hero",
          "label": "Hero",
          "settingsFields": [
            { "path": "templates.index.sections.hero_main.settings.eyebrow", "type": "text", "label": "Eyebrow" },
            { "path": "templates.index.sections.hero_main.settings.title", "type": "text", "label": "Title" },
            { "path": "templates.index.sections.hero_main.settings.subtitle", "type": "textarea", "label": "Subtitle" },
            { "path": "templates.index.sections.hero_main.settings.ctaLabel", "type": "text", "label": "Primary button" },
            { "path": "templates.index.sections.hero_main.settings.showCta", "type": "boolean", "label": "Show buttons" }
          ]
        },
        {
          "id": "featured_collection",
          "type": "featured-collection",
          "label": "Featured collection",
          "settingsFields": [
            { "path": "templates.index.sections.featured_collection.settings.title", "type": "text", "label": "Title" },
            { "path": "templates.index.sections.featured_collection.settings.productsToShow", "type": "number", "label": "Products to show" }
          ]
        },
        {
          "id": "promo_banner",
          "type": "image-banner",
          "label": "Promo banner",
          "settingsFields": [
            { "path": "templates.index.sections.promo_banner.settings.title", "type": "text", "label": "Title" },
            { "path": "templates.index.sections.promo_banner.settings.subtitle", "type": "text", "label": "Subtitle" }
          ]
        },
        {
          "id": "reviews",
          "type": "reviews",
          "label": "Reviews",
          "hasBlocks": true,
          "settingsFields": [
            { "path": "templates.index.sections.reviews.settings.title", "type": "text", "label": "Section title" }
          ]
        },
        {
          "id": "icons_with_text",
          "type": "icons-with-text",
          "label": "Icons with text",
          "hasBlocks": true,
          "settingsFields": [
            { "path": "templates.index.sections.icons_with_text.settings.title", "type": "text", "label": "Title" }
          ]
        }
      ]
    },
    {
      "id": "product",
      "label": "Product page",
      "sections": [
        {
          "id": "product_main",
          "type": "product-main",
          "label": "Product details",
          "settingsFields": [
            { "path": "templates.product.sections.product_main.settings.showIngredientsTab", "type": "boolean", "label": "Ingredients tab" },
            { "path": "templates.product.sections.product_main.settings.showReviewsTab", "type": "boolean", "label": "Reviews tab" }
          ]
        }
      ]
    }
  ]
}
